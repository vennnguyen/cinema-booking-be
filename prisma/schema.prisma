generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model cinema {
  cinemaId    Int     @id @default(autoincrement())
  cinemaName  String  @db.VarChar(150)
  province    String? @db.VarChar(100)
  address     String? @db.VarChar(300)
  description String? @db.Text
  status      Boolean @default(true)
  room        room[]
}

model combo {
  comboId     Int           @id @default(autoincrement())
  comboName   String        @db.VarChar(200)
  image       String?       @db.VarChar(500)
  description String?       @db.Text
  price       Decimal       @db.Decimal(12, 2)
  status      Boolean       @default(true)
  combodetail combodetail[]
  orderdetail orderdetail[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model movie {
  movieId        Int        @id @default(autoincrement())
  movieTypeId    Int
  movieName      String     @db.VarChar(1200)
  description    String?    @db.Text
  age            Int?
  imageLandscape String?    @db.VarChar(500)
  imagePortrait  String?    @db.VarChar(500)
  rate           Float?
  totalVotes     Int?
  startDate      DateTime?  @db.DateTime(0)
  endDate        DateTime?  @db.DateTime(0)
  slug           String?    @unique(map: "slug") @db.VarChar(100)
  trailer        String?    @db.VarChar(500)
  duration       Int
  createdAt      DateTime?  @default(now()) @db.DateTime(0)
  country        String?    @db.VarChar(200)
  producer       String?    @db.VarChar(500)
  director       String?    @db.VarChar(500)
  actors         Json?
  status         Boolean    @default(true)
  movietype      movietype  @relation(fields: [movieTypeId], references: [movieTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_movie_movietype")
  showtime       showtime[]

  @@index([movieTypeId], map: "fk_movie_movietype")
  @@index([slug], map: "idx_movie_slug")
  @@index([status], map: "idx_movie_status")
}

model movietype {
  movieTypeId   Int     @id @default(autoincrement())
  movieTypeName String  @db.VarChar(100)
  description   String? @db.Text
  status        Boolean @default(true)
  movie         movie[]
}

model order {
  orderId       Int                 @id @default(autoincrement())
  userId        Int
  totalPrice    Decimal             @default(0.00) @db.Decimal(12, 2)
  paymentStatus order_paymentStatus @default(PENDING)
  createdAt     DateTime            @default(now()) @db.DateTime(0)
  updatedAt     DateTime            @default(now()) @db.DateTime(0)
  status        Boolean             @default(true)
  user          user                @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_user")
  orderdetail   orderdetail[]
  payment       payment[]

  @@index([userId], map: "idx_order_user")
  @@index([paymentStatus], map: "idx_order_status")
}

model orderdetail {
  orderDetailId Int                  @id @default(autoincrement())
  orderId       Int
  ticketId      Int?
  comboId       Int?
  itemType      orderdetail_itemType
  quantity      Int                  @default(1)
  unitPrice     Decimal              @default(0.00) @db.Decimal(12, 2)
  status        Boolean              @default(true)
  combo         combo?               @relation(fields: [comboId], references: [comboId], onDelete: NoAction, onUpdate: NoAction, map: "fk_orderdetail_combo")
  order         order                @relation(fields: [orderId], references: [orderId], onDelete: NoAction, onUpdate: NoAction, map: "fk_orderdetail_order")
  ticket        ticket?              @relation(fields: [ticketId], references: [ticketId], onDelete: NoAction, onUpdate: NoAction, map: "fk_orderdetail_ticket")

  @@index([comboId], map: "fk_orderdetail_combo")
  @@index([ticketId], map: "fk_orderdetail_ticket")
  @@index([orderId], map: "idx_orderdetail_order")
}

model priceticket {
  priceTicketId Int        @id @default(autoincrement())
  roomTypeId    Int
  seatTypeId    Int
  ticketTypeId  Int
  price         Decimal    @db.Decimal(12, 2)
  status        Boolean    @default(true)
  roomtype      roomtype   @relation(fields: [roomTypeId], references: [roomTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_priceticket_roomtype")
  seattype      seattype   @relation(fields: [seatTypeId], references: [seatTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_priceticket_seattype")
  tickettype    tickettype @relation(fields: [ticketTypeId], references: [ticketTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_priceticket_tickettype")
  ticket        ticket[]

  @@unique([roomTypeId, seatTypeId, ticketTypeId], map: "uq_priceticket")
  @@index([seatTypeId], map: "fk_priceticket_seattype")
  @@index([ticketTypeId], map: "fk_priceticket_tickettype")
  @@index([roomTypeId, seatTypeId, ticketTypeId], map: "idx_priceticket_lookup")
}

model room {
  roomId     Int        @id @default(autoincrement())
  roomTypeId Int
  roomName   String     @db.VarChar(100)
  cinemaId   Int
  capacity   Int        @default(0)
  status     Boolean    @default(true)
  cinema     cinema     @relation(fields: [cinemaId], references: [cinemaId], onDelete: NoAction, onUpdate: NoAction, map: "fk_room_cinema")
  roomtype   roomtype   @relation(fields: [roomTypeId], references: [roomTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_room_roomtype")
  seat       seat[]
  showtime   showtime[]

  @@index([roomTypeId], map: "fk_room_roomtype")
  @@index([cinemaId], map: "idx_room_cinema")
}

model roomtype {
  roomTypeId   Int           @id @default(autoincrement())
  roomTypeName String        @db.VarChar(100)
  description  String?       @db.Text
  status       Boolean       @default(true)
  priceticket  priceticket[]
  room         room[]
}

model seat {
  seatId       Int            @id @default(autoincrement())
  seatTypeId   Int
  roomId       Int
  seatRow      String         @db.VarChar(10)
  seatColumn   Int
  status       Boolean        @default(true)
  room         room           @relation(fields: [roomId], references: [roomId], onDelete: NoAction, onUpdate: NoAction, map: "fk_seat_room")
  seattype     seattype       @relation(fields: [seatTypeId], references: [seatTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_seat_seattype")
  showtimeseat showtimeseat[]
  ticket       ticket[]

  @@index([seatTypeId], map: "fk_seat_seattype")
  @@index([roomId], map: "idx_seat_room")
}

model seattype {
  seatTypeId   Int           @id @default(autoincrement())
  seatTypeName String        @db.VarChar(100)
  description  String?       @db.Text
  status       Boolean       @default(true)
  priceticket  priceticket[]
  seat         seat[]
}

model showtime {
  showId       Int            @id @default(autoincrement())
  movieId      Int
  roomId       Int
  releaseDate  DateTime       @db.Date
  startTime    DateTime       @db.Time(0)
  endTime      DateTime       @db.Time(0)
  status       Boolean        @default(true)
  movie        movie          @relation(fields: [movieId], references: [movieId], onDelete: NoAction, onUpdate: NoAction, map: "fk_showtime_movie")
  room         room           @relation(fields: [roomId], references: [roomId], onDelete: NoAction, onUpdate: NoAction, map: "fk_showtime_room")
  showtimeseat showtimeseat[]
  ticket       ticket[]

  @@index([releaseDate], map: "idx_showtime_date")
  @@index([movieId], map: "idx_showtime_movie")
  @@index([roomId], map: "idx_showtime_room")
}

model ticket {
  ticketId      Int           @id @default(autoincrement())
  ticketTypeId  Int
  showId        Int
  seatId        Int
  priceTicketId Int
  qrCode        String?       @db.VarChar(500)
  createdAt     DateTime      @default(now()) @db.DateTime(0)
  status        Boolean       @default(true)
  orderdetail   orderdetail[]
  priceticket   priceticket   @relation(fields: [priceTicketId], references: [priceTicketId], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_priceticket")
  seat          seat          @relation(fields: [seatId], references: [seatId], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_seat")
  showtime      showtime      @relation(fields: [showId], references: [showId], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_showtime")
  tickettype    tickettype    @relation(fields: [ticketTypeId], references: [ticketTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_tickettype")

  @@unique([showId, seatId], map: "uq_ticket_show_seat")
  @@index([priceTicketId], map: "fk_ticket_priceticket")
  @@index([ticketTypeId], map: "fk_ticket_tickettype")
  @@index([seatId], map: "idx_ticket_seat")
  @@index([showId], map: "idx_ticket_show")
}

model tickettype {
  ticketTypeId   Int           @id @default(autoincrement())
  ticketTypeName String        @db.VarChar(100)
  description    String?       @db.Text
  status         Boolean       @default(true)
  priceticket    priceticket[]
  ticket         ticket[]
}

model user {
  userId      Int       @id @default(autoincrement())
  fullName    String    @db.VarChar(150)
  phoneNumber String?   @db.VarChar(20)
  dateOfBirth DateTime? @db.Date
  sex         user_sex?
  password    String    @db.VarChar(255)
  email       String    @unique(map: "email") @db.VarChar(150)
  role        user_role @default(USER)
  createdAt   DateTime  @default(now()) @db.DateTime(0)
  updatedAt   DateTime  @default(now()) @db.DateTime(0)
  status      Boolean   @default(true)
  order       order[]
  session     Session[]
}

model payment {
  paymentId     Int            @id @default(autoincrement())
  orderId       Int
  amount        Decimal        @db.Decimal(12, 2)
  method        payment_method
  transactionId String?        @db.VarChar(200)
  paidAt        DateTime?      @db.DateTime(0)
  createdAt     DateTime       @default(now()) @db.DateTime(0)
  status        Boolean        @default(true)
  order         order          @relation(fields: [orderId], references: [orderId], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_order")

  @@index([orderId], map: "idx_payment_order")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model showtimeseat {
  showTimeSeatId Int                 @id @default(autoincrement())
  showId         Int
  seatId         Int
  status         showtimeseat_status @default(AVAILABLE)
  heldUntil      DateTime?           @db.DateTime(0)
  seat           seat                @relation(fields: [seatId], references: [seatId], onDelete: NoAction, onUpdate: NoAction, map: "fk_showtimeseat_seat")
  showtime       showtime            @relation(fields: [showId], references: [showId], onDelete: NoAction, onUpdate: NoAction, map: "fk_showtimeseat_show")

  @@unique([showId, seatId], map: "uq_show_seat")
  @@index([seatId], map: "fk_showtimeseat_seat")
  @@index([showId], map: "idx_showtimeseat_show")
  @@index([status], map: "idx_showtimeseat_status")
}

model combodetail {
  comboDetailId Int     @id @default(autoincrement())
  comboId       Int
  productId     Int
  quantity      Int     @default(1)
  status        Boolean @default(true)
  combo         combo   @relation(fields: [comboId], references: [comboId], onDelete: NoAction, onUpdate: NoAction, map: "fk_combodetail_combo")
  product       product @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "fk_combodetail_product")

  @@index([productId], map: "fk_combodetail_product")
  @@index([comboId], map: "idx_combodetail_combo")
}

model product {
  productId     Int           @id @default(autoincrement())
  productTypeId Int
  name          String        @db.VarChar(200)
  image         String?       @db.VarChar(500)
  price         Decimal       @default(0.00) @db.Decimal(12, 2)
  status        Boolean       @default(true)
  combodetail   combodetail[]
  producttype   producttype   @relation(fields: [productTypeId], references: [productTypeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_product_producttype")

  @@index([productTypeId], map: "idx_product_type")
}

model producttype {
  productTypeId   Int       @id @default(autoincrement())
  productTypeName String    @db.VarChar(100)
  description     String?   @db.Text
  status          Boolean   @default(true)
  product         product[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Session {
  sessionId    Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique(map: "uq_session_token") @db.VarChar(500)
  expiresAt    DateTime @db.DateTime(0)
  createdAt    DateTime @default(now()) @db.DateTime(0)
  status       Boolean  @default(true)
  user         user     @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_session_user")

  @@index([expiresAt], map: "idx_session_expires")
  @@index([userId], map: "idx_session_user")
  @@map("session")
}

enum order_paymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum orderdetail_itemType {
  TICKET
  COMBO
  TICKET_COMBO @map("TICKET&COMBO")
}

enum user_sex {
  Male
  Female
  Other
}

enum payment_method {
  CASH
  MOMO
  VNPAY
  ZALOPAY
  CARD
}

enum showtimeseat_status {
  AVAILABLE
  HOLDING
  BOOKED
}

enum user_role {
  ADMIN
  USER
}
